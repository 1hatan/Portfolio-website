# Port the Express server listens on
PORT=5000

# MongoDB connection string.
# Local:  mongodb://127.0.0.1:27017/harani-portfolio
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/harani-portfolio
MONGO_URI=mongodb://127.0.0.1:27017/harani-portfolio

# Comma-separated list of origins allowed to call this API
CLIENT_ORIGIN=http://localhost:5173
